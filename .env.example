# Copy these into Vercel: Project Settings > Environment Variables.
# Do not put real values in this file or commit real secrets to git.

# Neon Postgres connection string (Neon dashboard > Connection Details).
# Use the "pooled connection" string.
DATABASE_URL=postgresql://user:password@ep-example-12345.us-east-2.aws.neon.tech/neondb?sslmode=require

# A password you make up yourself — required to view /crm.html.
ADMIN_KEY=change-me-to-a-long-random-passphrase
